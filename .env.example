# --- Tesla Analyzer configuration ---

# Database location (SQLite by default; any SQLAlchemy URL works)
DATABASE_URL=sqlite:///./data/tesla_analyzer.db

# Tesla Fleet API / Owner API access token.
# Leave blank to run in DEMO mode with generated sample data.
TESLA_ACCESS_TOKEN=
TESLA_REFRESH_TOKEN=

# Tesla API base URL (region dependent for the Fleet API).
# Owner API:  https://owner-api.teslamotors.com
# Fleet API:  https://fleet-api.prd.na.vn.cloud.tesla.com
TESLA_API_BASE_URL=https://owner-api.teslamotors.com

# Secret that lets an external cron service call /api/sync?key=<SYNC_KEY>
# without the passcode, for hands-off background logging. Empty = disabled.
SYNC_KEY=

# Where GET /api/backup?key=<SYNC_KEY> POSTs a full-history export ZIP
# (application/zip, raw bytes) — your own upload endpoint, a cloud-storage
# presigned PUT URL, or a relay that forwards to email. Empty = disabled
# (the endpoint returns 400 instead of silently no-op'ing). Point a second,
# infrequent (daily/weekly) cron job at it.
BACKUP_WEBHOOK_URL=

# Where GET /api/reports/monthly?key=<SYNC_KEY> POSTs a driving/charging/
# efficiency summary (JSON, includes a "text" field a Slack/Discord incoming
# webhook reads directly). Empty = disabled (the endpoint returns 400
# instead of silently no-op'ing). Point a monthly cron job at it — add
# ?days=N to change the summarised period (default 30).
REPORT_WEBHOOK_URL=

# Generic event webhook: POSTs {event, title, body, timestamp} on charge
# complete, low battery, and drive complete — for home automation (Home
# Assistant, IFTTT, Zapier, n8n, ...). Independent of push notifications
# below (works with either, both, or neither configured). Empty = disabled.
EVENT_WEBHOOK_URL=

# Web push notifications (charge complete, low battery). Generate a keypair
# with `python run.py push-keys` and paste both lines it prints here — empty
# (either one) disables notifications: the "Enable notifications" button
# stays hidden and /api/push/* returns 404.
VAPID_PRIVATE_KEY_PEM=
VAPID_PUBLIC_KEY_PEM=
VAPID_SUBJECT_EMAIL=admin@example.com
# Push a "Battery low" alert once when SoC drops to/below this. 0 = disabled.
LOW_SOC_NOTIFY_PCT=0

# --- Tesla OAuth (only needed for the "Sign in with Tesla" button) ---
# Register a developer app at https://developer.tesla.com to obtain these.
# The OAuth callback URL is derived automatically from the live host:
#   https://<your-host>/api/link/oauth/callback
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_OAUTH_SCOPE=openid offline_access vehicle_device_data
TESLA_OAUTH_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com

# Polling interval in seconds when the collector runs against the live API.
POLL_INTERVAL_SECONDS=60

# Energy price used for charging cost estimates (currency per kWh).
ENERGY_PRICE_PER_KWH=0.90
CURRENCY=RM

# Optional time-of-use pricing: driving/charging cost prices each session by
# its own start time instead of the flat rate above. Both must be > 0 to
# enable it; leave blank/0 to keep the flat ENERGY_PRICE_PER_KWH everywhere.
ENERGY_PRICE_PEAK_KWH=
ENERGY_PRICE_OFFPEAK_KWH=
TARIFF_PEAK_START_HOUR=8
TARIFF_PEAK_END_HOUR=22
TARIFF_WEEKEND_OFFPEAK=true

# Optional petrol comparator (TCO): what this window's distance would have
# cost in an equivalent petrol car, shown as a "vs Petrol" KPI card. Both
# must be > 0 to enable it — leave blank/0 to hide the card (no assumed
# "average car" figure is guessed).
PETROL_PRICE_PER_LITER=
PETROL_L_PER_100KM=

# Rated/EPA efficiency for your model in Wh/km (used as efficiency baseline).
RATED_WH_PER_KM=150
